# Configuration Delirium AI
# Copier en .env et remplir les valeurs

# ═══ LLM BACKBONE ═══
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_MODEL_FAST=MiniMax-M2.7-highspeed

# ═══ USAGE ═══
# S1 (réponse utilisateur)  : MiniMax-M2.7        ($0.30/1M in, $1.20/1M out)
# S2 (métacognition async)  : MiniMax-M2.7-highspeed ($0.60/1M in, $2.40/1M out, plus rapide)
# Vie autonome / notes      : MiniMax-M2.7-highspeed
# Vision du monde (synthèse): MiniMax-M2.7

# ═══ EMBEDDINGS ═══
# À définir : MiniMax embedding API ou alternative (OpenAI text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=

# ═══ BASE DE DONNÉES ═══
SQLITE_DB_PATH=./data/delirium.db
SQLITE_ENCRYPTION_KEY=  # clé SQLCipher, générée automatiquement si vide
VECTOR_DB_PATH=./data/vectors/
VECTOR_DB_ENGINE=chromadb  # chromadb ou lancedb

# ═══ OSINT (onboarding) ═══
# OSINT_ENABLED=false
# OSINT_APIS=  # à configurer selon les APIs disponibles

# ═══ COLD WEAVER ═══
# ARXIV_ENABLED=false
# GITHUB_TOKEN=  # pour GitHub API trending
# RSS_FEEDS=  # URLs séparées par des virgules
